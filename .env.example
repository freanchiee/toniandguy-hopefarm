NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_WHATSAPP_NUMBER=919187200430
# Instagram Basic Display API - long-lived token from developers.facebook.com/apps
INSTAGRAM_ACCESS_TOKEN=

# Supabase service role key (for server-side writes)
SUPABASE_SERVICE_ROLE_KEY=

# OpenWA - free self-hosted WhatsApp gateway (no Twilio needed)
# Run: docker run -d -p 8002:8002 --name openwa openwa/wa-automate
# Then scan QR at http://localhost:8002 with your WhatsApp
OPENWA_URL=http://localhost:8002
OPENWA_API_KEY=

# Secret for /api/reminders cron endpoint
CRON_SECRET=
